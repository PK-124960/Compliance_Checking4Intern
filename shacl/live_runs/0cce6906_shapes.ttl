ex:GS_001Shape
    a sh:NodeShape ;
    sh:targetClass ex:Student ;
    sh:property [
        sh:path ex:GS_001_compliance ;
        sh:minCount 1 ;
        sh:severity sh:Info ;
        sh:message "Compliance required for GS_001" ;
    ] .


