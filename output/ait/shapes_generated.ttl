@prefix ait: <http://example.org/ait-policy#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

ait:AIT_0103Shape a sh:NodeShape ;
    sh:targetClass ?x ;
    sh:property [ sh:path ait:deniesOrGrantsRight ;
                   sh:minCount 1 ;
                   sh:severity sh:Violation ] ;
    sh:property [ sh:path ait:basisOfDenialOrGrant ;
                   sh:valueType sh:string ;
                   sh:inClass sh:String ;
                   sh:excludedValue "nationality" ;
                   sh:excludedValue "race" ;
                   sh:excludedValue "social background" ;
                   sh:excludedValue "gender" ;
                   sh:excludedValue "age" ;
                   sh:excludedValue "marital status" ;
                   sh:excludedValue "family status" ;
                   sh:excludedValue "sexual orientation" ;
                   sh:excludedValue "disability" ;
                   sh:type sh:List ] ;
    ^^^^;

The semicolon at the end of the line defining the `sh:property` for `ait:basisOfDenialOrGrant` was added to fix the syntax error.
