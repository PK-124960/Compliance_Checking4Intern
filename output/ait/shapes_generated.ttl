ait:AIT_0439Shape a sh:NodeShape ;
    sh:targetSubjectsOf ait:provideIdentification ;
    sh:severity sh:Violation ;
    sh:property ait:AIT_0439Shape_prop1 .

ait:AIT_0439Shape_prop1 a sh:PropertyShape ;
    sh:path ait:provideIdentification ;
    sh:minCount 1 ;
    sh:message "If ID card is not available, other form of identification should be provided." .

# Rule: AIT-0441 | PERMISSION
# FOL: P(bringBicycle)
ait:AIT_0441Shape a sh:NodeShape ;
    sh:targetSubjectsOf ait:bringBicycle ;
    sh:severity sh:Info ;
    sh:property ait:AIT_0441Shape_prop1 .

ait:AIT_0441Shape_prop1 a sh:PropertyShape ;
    sh:path ait:bringBicycle ;
    sh:minCount 0 ;
    sh:message "You may prefer to bring a bicycle with you." .

# Rule: AIT-0443 | OBLIGATION
# FOL: O(reserveVehicleByFacultyMemberOrSeniorAdminStaffMemberOrStudentUnionPresident)
ait:AIT_0443Shape a sh:NodeShape ;
    sh:targetClass ait:Resident ;
    sh:severity sh:Violation ;
    sh:property ait:AIT_0443Shape_prop1 .

ait:AIT_0443Shape_prop1 a sh:PropertyShape ;
    sh:path ait:reserveVehicleByFacultyMemberOrSeniorAdminStaffMemberOrStudentUnionPresident ;
    sh:minCount 1 ;
    sh:message "In all such cases, the reservation of the vehicle must be made by a member of the faculty or a senior administrative staff member in the School or by the Student Union President to the Motor Pool." .

# Rule: AIT-0445 | PERMISSION
# FOL: P(takeBus(rangsit, nonAirConditioned))
ait:AIT_0445Shape a sh:NodeShape ;
    sh:targetSubjectsOf ait:takeBus ;
    sh:severity sh:Info ;
    sh:property ait:AIT_0445Shape_prop1 .

ait:AIT_0445Shape_prop1 a sh:PropertyShape ;
    sh:path ait:takeBus ;
    sh:minCount 0 ;
    sh:message "From Rangsit, you may take the following buses: Non-air-conditioned Bus No." .

# Rule: AIT-0446 | OBLIGATION
# FOL: F(paid_in_full(s, d))
ait:AIT_0446Shape a sh:NodeShape ;
    sh:targetSubjectsOf ait:paid_in_full ;
    sh:severity sh:Violation ;
    sh:property ait:AIT_0446Shape_prop1 .

ait:AIT_0446Shape_prop1 a sh:PropertyShape ;
    sh:path ait:paid_in_full ;
    sh:minCount 1 ;
    sh:message "Fares for the latter should always be agreed in advance with the driver, and must be paid in full on arrival at the destination." .

# Rule: AIT-0447 | PERMISSION
# FOL: P(waits_at_location(x))
ait:AIT_0447Shape a sh:NodeShape ;
    sh:targetClass ait:Student ;
    sh:severity sh:Info ;
    sh:property ait:AIT_0447Shape_prop1 .

ait:AIT_0447Shape_prop1 a sh:PropertyShape ;
    sh:path ait:waits_at_location ;
    sh:minCount 0 ;
    sh:message "Students may wait for the vans at the Thammasat Road near AIT Gate No. 2 or at the bus stop near the AIT Front Gate No." .

