@prefix ait: <http://example.org/ait-policy#> .
@prefix deontic: <http://example.org/deontic#> .

ait:PolicyOntology a owl:Ontology .
deontic:obligation a rdfs:Class .
deontic:permission a rdfs:Class .
deontic:prohibition a rdfs:Class .

ait:Gs001Shape a sh:NodeShape ;
    sh:targetClass ait:Confidentiality ;
    rdfs:label "GS-001" ;
    rdfs:comment "Contracted research may entail confidentiality and restriction on publication." ;
    deontic:type deontic:obligation ;
    sh:severity sh:Violation ;
    sh:property [ sh:path ait:r ; sh:minCount 1 ] ;
    sh:property [ sh:path ait:r ; sh:minCount 1 ] ;
    sh:property [ sh:path ait:contractedresearch ; sh:minCount 1 ] .

ait:Gs002Shape a sh:NodeShape ;
    sh:targetClass ait:Cancelled ;
